    "@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0-rc.4",
    "@cliffy/table": "jsr:@cliffy/table@^1.0.0-rc.4",
    "@cross/dir": "jsr:@cross/dir@^1.1.0",
    "@officialrajdeepsingh/slugify": "jsr:@officialrajdeepsingh/slugify@^0.1.1",
    "@std/assert": "jsr:@std/assert@^0.224.0",
    "@std/path": "jsr:@std/path@^0.224.0",
    "@std/ulid": "jsr:@std/ulid@^0.224.0",
    "ink": "npm:ink@4.4.1",
