{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
  "name": "@downtimer/cli",
  "version": "0.5.1",
  "exports": {},
  "tasks": {
    "start": "deno run --allow-net --allow-read --allow-write --allow-env --allow-sys ./main.ts",
    "start:debug": "deno run --allow-net --allow-read --allow-write --allow-env --allow-sys --inspect-brk ./main.ts",
    "compile:windows": "deno compile --allow-net --allow-read --allow-write --allow-env --allow-sys --target=\"x86_64-pc-windows-msvc\" --output=./dist/dt-x86_64-pc-windows-msvc.exe main.ts",
    "compile:linux": "deno compile --allow-net --allow-read --allow-write --allow-env --allow-sys --target=\"x86_64-unknown-linux-gnu\" --output=./dist/dt-x86_64-unknown-linux-gnu main.ts",
    "compile:mac": "deno compile --allow-net --allow-read --allow-write --allow-env --allow-sys --target=\"x86_64-apple-darwin\" --output=./dist/dt-x86_64-apple-darwin.dmg main.ts",
    "compile:mac-arm": "deno compile --allow-net --allow-read --allow-write --allow-env --allow-sys --target=\"aarch64-apple-darwin\" --output=./dist/dt-aarch64-apple-darwin.dmg main.ts",
    "compile:all": "deno task compile:windows && deno task compile:linux && deno task compile:mac && deno task compile:mac-arm",
    "compile:host": "deno compile --allow-net --allow-read --allow-write --allow-env --allow-sys main.ts",
    "test": "deno test --allow-net --allow-read --allow-write --allow-env --allow-sys --coverage",
    "coverage": "deno coverage --html"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react"
  },
  "imports": {
    "@cliffy/ansi": "jsr:@cliffy/ansi@^1.0.0",
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0",
    "@cliffy/keypress": "jsr:@cliffy/keypress@^1.0.0",
    "@cliffy/prompt": "jsr:@cliffy/prompt@^1.0.0",
    "@cliffy/table": "jsr:@cliffy/table@^1.0.0",
    "@cross/dir": "jsr:@cross/dir@^1.1.1",
    "@officialrajdeepsingh/slugify": "jsr:@officialrajdeepsingh/slugify@^0.1.1",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/ulid": "jsr:@std/ulid@^1.0.0",
    "ink": "npm:ink@^7.0.0",
    "ink-big-text": "npm:ink-big-text@2.0.0",
    "react": "npm:react@^19.2.5",
    "@types/react": "npm:@types/react@19.2.14"
  }
}