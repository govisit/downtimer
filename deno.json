{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/main/cli/schemas/config-file.v1.json",
  "nodeModulesDir": "auto",
  "vendor": true,
  "tasks": {
    "web:build:image": "podman build --build-arg GIT_REVISION=$(git rev-parse HEAD) -t dt-web:latest -f ./web/Dockerfile ."
  },
  "workspace": [
    "./web",
    "./cli",
    "./shared"
  ],
  "compilerOptions": {
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "strictNullChecks": true
  }
}
