{
  "$schema": "https://raw.githubusercontent.com/denoland/deno/refs/heads/main/cli/schemas/config-file.v1.json",
  "nodeModulesDir": "auto",
  "vendor": true,
  "tasks": {
    "web:build:image": "podman build --build-arg GIT_REVISION=$(git rev-parse HEAD) -t ghcr.io/govisit/dt-web:latest -f ./web/Dockerfile ."
  },
  "workspace": [
    "./web",
    "./cli",
    "./shared"
  ],
  "compilerOptions": {
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "strictNullChecks": true
  },
  "allowScripts": [
    "npm:@tailwindcss/oxide@4.1.14",
    "npm:esbuild@0.25.10",
    "npm:esbuild@0.25.7"
  ]
}
